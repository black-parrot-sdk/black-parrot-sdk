From 3c3f2d2d00a32f3c491ca77c3e1379558db20082 Mon Sep 17 00:00:00 2001
From: Dan Ruelas-Petrisko <petrisko.bsg@gmail.com>
Date: Mon, 20 Apr 2026 14:07:04 -0700
Subject: [PATCH] Adding fPIC

---
 CMakeLists.txt | 1 +
 1 file changed, 1 insertion(+)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index bf7f218..45ad21b 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -53,20 +53,21 @@ add_compile_options(
         -std=c++11
         -g
         -Wall
         -Wno-parentheses
         -MMD
         -D_FILE_OFFSET_BITS=64
         -D_LARGEFILE_SOURCE
         -D_GNU_SOURCE
         -D__STDC_FORMAT_MACROS
         -march=native -mtune=native
+        -fPIC
 )
 
 add_link_options(
 )
 
 add_compile_options($<$<CONFIG:Release>:-Ofast>)
 
 if (TRACEOS)
     message(STATUS "TRACEOS is on.")
     add_compile_options(
-- 
2.18.4

